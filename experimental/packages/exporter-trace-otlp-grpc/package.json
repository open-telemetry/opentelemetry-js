{
  "name": "@opentelemetry/exporter-trace-otlp-grpc",
  "version": "0.220.0",
  "description": "OpenTelemetry Collector Exporter allows user to send collected traces to the OpenTelemetry Collector",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": "open-telemetry/opentelemetry-js",
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "clean": "rimraf dist build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tdd": "npm run test -- --watch-extensions ts --watch",
    "test": "nyc mocha 'test/**/*.test.ts'",
    "version": "node ../../../scripts/version-update.js",
    "watch": "tsc --watch --build",
    "peer-api-check": "node ../../../scripts/peer-api-check.js",
    "align-api-deps": "node ../../../scripts/align-api-deps.js"
  },
  "keywords": [
    "opentelemetry",
    "nodejs",
    "grpc",
    "tracing",
    "profiling",
    "metrics",
    "stats"
  ],
  "author": "OpenTelemetry Authors",
  "license": "Apache-2.0",
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "files": [
    "doc",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@grpc/proto-loader": "^0.8.0",
    "@opentelemetry/api": "1.9.1",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.130",
    "@types/sinon": "17.0.4",
    "mocha": "11.7.6",
    "nyc": "17.1.0",
    "sinon": "18.0.1",
    "ts-loader": "9.5.7",
    "typescript": "5.0.4"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.3.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@opentelemetry/otlp-exporter-base": "0.220.0",
    "@opentelemetry/otlp-grpc-exporter-base": "0.220.0",
    "@opentelemetry/otlp-transformer": "0.220.0",
    "@opentelemetry/sdk-trace": "2.9.0"
  },
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/experimental/packages/exporter-trace-otlp-grpc",
  "sideEffects": false
}
