{
  "name": "@opentelemetry/core",
  "version": "2.7.1",
  "description": "OpenTelemetry Core provides constants and utilities shared by all OpenTelemetry SDK packages.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./platform": {
      "import": {
        "types": "./dist/platform/index.d.mts",
        "default": "./dist/platform/index.mjs"
      },
      "require": {
        "types": "./dist/platform/index.d.cts",
        "default": "./dist/platform/index.cjs"
      }
    },
    "./platform/browser": {
      "import": {
        "types": "./dist/platform/browser/index.d.mts",
        "default": "./dist/platform/browser/index.mjs"
      },
      "require": {
        "types": "./dist/platform/browser/index.d.cts",
        "default": "./dist/platform/browser/index.cjs"
      }
    }
  },
  "browser": {
    "./dist/platform/node/environment.mjs": "./dist/platform/browser/environment.mjs",
    "./dist/platform/node/environment.cjs": "./dist/platform/browser/environment.cjs",
    "./dist/platform/node/index.mjs": "./dist/platform/browser/index.mjs",
    "./dist/platform/node/index.cjs": "./dist/platform/browser/index.cjs",
    "./dist/platform/node/sdk-info.mjs": "./dist/platform/browser/sdk-info.mjs",
    "./dist/platform/node/sdk-info.cjs": "./dist/platform/browser/sdk-info.cjs",
    "./dist/platform/index.mjs": "./dist/platform/browser/index.mjs",
    "./dist/platform/index.cjs": "./dist/platform/browser/index.cjs"
  },
  "repository": "open-telemetry/opentelemetry-js",
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "clean": "rimraf dist build",
    "test": "nyc mocha 'test/**/*.test.ts' --exclude 'test/browser/**/*.ts'",
    "test:browser": "karma start --single-run",
    "tdd": "npm run tdd:node",
    "tdd:node": "npm run test -- --watch-extensions ts --watch",
    "tdd:browser": "karma start",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "version": "node ../../scripts/version-update.js",
    "watch": "tsdown --watch --no-clean",
    "test:bench": "node test/performance/benchmark/index.js | tee .benchmark-results.txt",
    "peer-api-check": "node ../../scripts/peer-api-check.js",
    "align-api-deps": "node ../../scripts/align-api-deps.js"
  },
  "keywords": [
    "opentelemetry",
    "nodejs",
    "browser",
    "tracing",
    "profiling",
    "metrics",
    "stats"
  ],
  "author": "OpenTelemetry Authors",
  "license": "Apache-2.0",
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "files": [
    "doc",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opentelemetry/api": ">=1.0.0 <1.10.0",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.130",
    "@types/sinon": "17.0.4",
    "@types/webpack-env": "1.16.3",
    "babel-plugin-istanbul": "8.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage": "2.2.1",
    "karma-mocha": "2.0.1",
    "karma-spec-reporter": "0.0.36",
    "karma-webpack": "5.0.1",
    "mocha": "11.7.5",
    "nyc": "17.1.0",
    "sinon": "18.0.1",
    "ts-loader": "9.5.4",
    "typescript": "5.0.4",
    "webpack": "5.104.1"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.0.0 <1.10.0"
  },
  "dependencies": {
    "@opentelemetry/semantic-conventions": "^1.29.0"
  },
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/packages/opentelemetry-core",
  "sideEffects": false
}
