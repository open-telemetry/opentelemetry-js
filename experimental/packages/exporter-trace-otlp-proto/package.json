{
  "name": "@opentelemetry/exporter-trace-otlp-proto",
  "version": "0.220.0",
  "description": "OpenTelemetry Collector Exporter allows user to send collected traces to the OpenTelemetry Collector using protobuf over HTTP",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./platform": {
      "import": {
        "types": "./dist/platform/index.d.mts",
        "default": "./dist/platform/index.mjs"
      },
      "require": {
        "types": "./dist/platform/index.d.cts",
        "default": "./dist/platform/index.cjs"
      }
    },
    "./platform/browser": {
      "import": {
        "types": "./dist/platform/browser/index.d.mts",
        "default": "./dist/platform/browser/index.mjs"
      },
      "require": {
        "types": "./dist/platform/browser/index.d.cts",
        "default": "./dist/platform/browser/index.cjs"
      }
    }
  },
  "browser": {
    "./dist/platform/node/OTLPTraceExporter.mjs": "./dist/platform/browser/OTLPTraceExporter.mjs",
    "./dist/platform/node/OTLPTraceExporter.cjs": "./dist/platform/browser/OTLPTraceExporter.cjs",
    "./dist/platform/index.mjs": "./dist/platform/browser/index.mjs",
    "./dist/platform/index.cjs": "./dist/platform/browser/index.cjs"
  },
  "repository": "open-telemetry/opentelemetry-js",
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "clean": "rimraf dist build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tdd": "npm run test -- --watch-extensions ts --watch",
    "test": "nyc mocha 'test/**/*.test.ts' --exclude 'test/browser/**/*.ts'",
    "test:browser": "karma start --single-run",
    "version": "node ../../../scripts/version-update.js",
    "watch": "tsdown --watch --no-clean",
    "peer-api-check": "node ../../../scripts/peer-api-check.js",
    "align-api-deps": "node ../../../scripts/align-api-deps.js"
  },
  "keywords": [
    "opentelemetry",
    "nodejs",
    "protobuf",
    "tracing",
    "profiling",
    "metrics",
    "stats"
  ],
  "author": "OpenTelemetry Authors",
  "license": "Apache-2.0",
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "files": [
    "doc",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@opentelemetry/api": "1.9.1",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.130",
    "@types/sinon": "17.0.4",
    "babel-plugin-istanbul": "8.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage": "2.2.1",
    "karma-mocha": "2.0.1",
    "karma-spec-reporter": "0.0.36",
    "karma-webpack": "5.0.1",
    "mocha": "11.7.6",
    "nyc": "17.1.0",
    "sinon": "18.0.1",
    "ts-loader": "9.5.7",
    "typescript": "5.0.4",
    "webpack": "5.104.1",
    "webpack-cli": "7.0.3"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.3.0"
  },
  "dependencies": {
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/otlp-exporter-base": "0.220.0",
    "@opentelemetry/otlp-transformer": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace": "2.9.0"
  },
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/experimental/packages/exporter-trace-otlp-proto",
  "sideEffects": false
}
