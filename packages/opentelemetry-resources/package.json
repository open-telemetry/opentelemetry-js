{
  "name": "@opentelemetry/resources",
  "version": "2.7.1",
  "description": "OpenTelemetry SDK resources",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./detectors/platform": {
      "import": {
        "types": "./dist/detectors/platform/index.d.mts",
        "default": "./dist/detectors/platform/index.mjs"
      },
      "require": {
        "types": "./dist/detectors/platform/index.d.cts",
        "default": "./dist/detectors/platform/index.cjs"
      }
    },
    "./detectors/platform/browser": {
      "import": {
        "types": "./dist/detectors/platform/browser/index.d.mts",
        "default": "./dist/detectors/platform/browser/index.mjs"
      },
      "require": {
        "types": "./dist/detectors/platform/browser/index.d.cts",
        "default": "./dist/detectors/platform/browser/index.cjs"
      }
    }
  },
  "browser": {
    "./dist/detectors/platform/node/HostDetector.mjs": "./dist/detectors/platform/browser/HostDetector.mjs",
    "./dist/detectors/platform/node/HostDetector.cjs": "./dist/detectors/platform/browser/HostDetector.cjs",
    "./dist/detectors/platform/node/OSDetector.mjs": "./dist/detectors/platform/browser/OSDetector.mjs",
    "./dist/detectors/platform/node/OSDetector.cjs": "./dist/detectors/platform/browser/OSDetector.cjs",
    "./dist/detectors/platform/node/ProcessDetector.mjs": "./dist/detectors/platform/browser/ProcessDetector.mjs",
    "./dist/detectors/platform/node/ProcessDetector.cjs": "./dist/detectors/platform/browser/ProcessDetector.cjs",
    "./dist/detectors/platform/node/ServiceInstanceIdDetector.mjs": "./dist/detectors/platform/browser/ServiceInstanceIdDetector.mjs",
    "./dist/detectors/platform/node/ServiceInstanceIdDetector.cjs": "./dist/detectors/platform/browser/ServiceInstanceIdDetector.cjs",
    "./dist/detectors/platform/node/index.mjs": "./dist/detectors/platform/browser/index.mjs",
    "./dist/detectors/platform/node/index.cjs": "./dist/detectors/platform/browser/index.cjs",
    "./dist/detectors/platform/index.mjs": "./dist/detectors/platform/browser/index.mjs",
    "./dist/detectors/platform/index.cjs": "./dist/detectors/platform/browser/index.cjs"
  },
  "repository": "open-telemetry/opentelemetry-js",
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "clean": "rimraf dist build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "nyc mocha 'test/**/*.test.ts'",
    "test:browser": "karma start --single-run",
    "test:webworker": "karma start karma.worker.js --single-run",
    "tdd": "npm run test -- --watch-extensions ts --watch",
    "version": "node ../../scripts/version-update.js",
    "peer-api-check": "node ../../scripts/peer-api-check.js",
    "align-api-deps": "node ../../scripts/align-api-deps.js"
  },
  "keywords": [
    "opentelemetry",
    "nodejs",
    "resources",
    "stats",
    "profiling"
  ],
  "author": "OpenTelemetry Authors",
  "license": "Apache-2.0",
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "files": [
    "doc",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opentelemetry/api": ">=1.3.0 <1.10.0",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.130",
    "@types/sinon": "17.0.4",
    "@types/webpack-env": "1.16.3",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage": "2.2.1",
    "karma-mocha": "2.0.1",
    "karma-mocha-webworker": "1.3.0",
    "karma-spec-reporter": "0.0.36",
    "karma-webpack": "5.0.1",
    "mocha": "11.7.5",
    "nock": "13.5.6",
    "nyc": "17.1.0",
    "sinon": "18.0.1",
    "typescript": "5.0.4",
    "webpack": "5.104.1",
    "webpack-cli": "7.0.2"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.3.0 <1.10.0"
  },
  "dependencies": {
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/semantic-conventions": "^1.29.0"
  },
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/packages/opentelemetry-resources",
  "sideEffects": false
}
