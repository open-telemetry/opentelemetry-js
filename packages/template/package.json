{
  "name": "@opentelemetry/template",
  "version": "2.8.0",
  "description": "> TODO: description",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "author": "OpenTelemetry Authors",
  "Update homepage location": "https://github.com/open-telemetry/opentelemetry-js/tree/main/packages/template",
  "license": "Apache-2.0",
  "Add these only if the package has platform-conditional code (see @opentelemetry/core for a real example)": {
    "browser": {
      "./dist/platform/node/index.mjs": "./dist/platform/browser/index.mjs",
      "./dist/platform/node/index.cjs": "./dist/platform/browser/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-telemetry/opentelemetry-js.git"
  },
  "bugs": {
    "url": "https://github.com/open-telemetry/opentelemetry-js/issues"
  },
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "version": "node ../../scripts/version-update.js",
    "clean": "rimraf dist build",
    "peer-api-check": "node ../../scripts/peer-api-check.js",
    "align-api-deps": "node ../../scripts/align-api-deps.js"
  },
  "Add these to scripts": {
    "test": "nyc mocha 'test/**/*.test.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "watch": "tsdown --watch --no-clean"
  },
  "Add these to scripts if browser is supported": {
    "tdd": "karma start",
    "test:browser": "karma start --single-run"
  },
  "keywords": [
    "opentelemetry",
    "nodejs",
    "browser",
    "tracing",
    "profiling",
    "metrics",
    "stats",
    "monitoring"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "18.19.130",
    "typescript": "5.0.4"
  },
  "Add these to devDependencies for testing": {
    "@types/mocha": "10.0.10",
    "@types/sinon": "17.0.4",
    "mocha": "11.7.5",
    "nyc": "17.1.0",
    "sinon": "18.0.1"
  },
  "Add these to devDependencies if browser is targeted": {
    "@types/webpack-env": "1.16.3",
    "babel-plugin-istanbul": "8.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage": "2.2.1",
    "karma-mocha": "2.0.1",
    "karma-spec-reporter": "0.0.36",
    "karma-webpack": "5.0.1",
    "ts-loader": "9.5.7",
    "webpack": "5.104.1"
  }
}
