{
  "name": "@opentelemetry/configuration",
  "version": "0.220.0",
  "description": "OpenTelemetry Configuration",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": "open-telemetry/opentelemetry-js",
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "clean": "rimraf dist build",
    "generate:config": "node ./scripts/generate-config.js",
    "test": "nyc mocha test/**/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "version": "node ../../../scripts/version-update.js",
    "watch": "tsdown --watch --no-clean",
    "peer-api-check": "node ../../../scripts/peer-api-check.js",
    "align-api-deps": "node ../../../scripts/align-api-deps.js"
  },
  "keywords": [
    "opentelemetry",
    "configuration"
  ],
  "author": "OpenTelemetry Authors",
  "license": "Apache-2.0",
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opentelemetry/core": "2.9.0",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.130",
    "@types/sinon": "17.0.4",
    "ajv": "^8.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "mocha": "11.7.6",
    "nyc": "17.1.0",
    "sinon": "18.0.1",
    "ts-loader": "9.5.7",
    "typescript": "5.0.4"
  },
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/experimental/packages/configuration",
  "sideEffects": false
}
