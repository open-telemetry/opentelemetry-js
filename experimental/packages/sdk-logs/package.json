{
  "name": "@opentelemetry/sdk-logs",
  "version": "0.219.0",
  "description": "OpenTelemetry logs SDK",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./platform": {
      "import": {
        "types": "./dist/platform/index.d.mts",
        "default": "./dist/platform/index.mjs"
      },
      "require": {
        "types": "./dist/platform/index.d.cts",
        "default": "./dist/platform/index.cjs"
      }
    },
    "./platform/browser": {
      "import": {
        "types": "./dist/platform/browser/index.d.mts",
        "default": "./dist/platform/browser/index.mjs"
      },
      "require": {
        "types": "./dist/platform/browser/index.d.cts",
        "default": "./dist/platform/browser/index.cjs"
      }
    }
  },
  "browser": {
    "./dist/platform/node/export/BatchLogRecordProcessor.mjs": "./dist/platform/browser/export/BatchLogRecordProcessor.mjs",
    "./dist/platform/node/export/BatchLogRecordProcessor.cjs": "./dist/platform/browser/export/BatchLogRecordProcessor.cjs",
    "./dist/platform/index.mjs": "./dist/platform/browser/index.mjs",
    "./dist/platform/index.cjs": "./dist/platform/browser/index.cjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "OpenTelemetry Authors",
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/experimental/packages/sdk-logs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-telemetry/opentelemetry-js.git"
  },
  "bugs": {
    "url": "https://github.com/open-telemetry/opentelemetry-js/issues"
  },
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "clean": "rimraf dist build",
    "test": "nyc mocha 'test/**/*.test.ts'",
    "test:browser": "karma start --single-run",
    "tdd": "npm run test -- --watch-extensions ts --watch",
    "tdd:browser": "karma start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "version": "node ../../../scripts/version-update.js",
    "watch": "tsdown --watch --no-clean",
    "prewatch": "node ../../../scripts/version-update.js",
    "peer-api-check": "node ../../../scripts/peer-api-check.js",
    "align-api-deps": "node ../../../scripts/align-api-deps.js"
  },
  "keywords": [
    "opentelemetry",
    "nodejs",
    "logs",
    "stats",
    "profiling"
  ],
  "files": [
    "doc",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "@opentelemetry/api": ">=1.4.0 <1.10.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.6",
    "@babel/preset-env": "7.29.5",
    "@opentelemetry/api": ">=1.4.0 <1.10.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.130",
    "@types/sinon": "17.0.4",
    "babel-plugin-istanbul": "8.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage": "2.2.1",
    "karma-mocha": "2.0.1",
    "karma-spec-reporter": "0.0.36",
    "karma-webpack": "5.0.1",
    "mocha": "11.7.5",
    "nyc": "17.1.0",
    "sinon": "18.0.1",
    "ts-loader": "9.5.7",
    "typescript": "5.0.4",
    "webpack": "5.104.1",
    "webpack-cli": "7.0.2"
  },
  "dependencies": {
    "@opentelemetry/api-logs": "0.219.0",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/semantic-conventions": "^1.29.0"
  }
}
