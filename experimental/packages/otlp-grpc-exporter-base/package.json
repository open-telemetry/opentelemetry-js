{
  "name": "@opentelemetry/otlp-grpc-exporter-base",
  "version": "0.217.0",
  "description": "OpenTelemetry OTLP-gRPC Exporter base (for internal use only)",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": "open-telemetry/opentelemetry-js",
  "scripts": {
    "prepublishOnly": "npm run compile",
    "compile": "tsdown",
    "clean": "rimraf dist build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "tdd": "npm run test -- --watch-extensions ts --watch",
    "test": "nyc mocha 'test/**/*.test.ts'",
    "version": "node ../../../scripts/version-update.js",
    "watch": "tsc -w",
    "align-api-deps": "node ../../../scripts/align-api-deps.js",
    "maint:regenerate-test-certs": "cd test/certs && ./regenerate.sh"
  },
  "keywords": [
    "opentelemetry",
    "nodejs",
    "grpc",
    "tracing",
    "profiling",
    "metrics",
    "stats"
  ],
  "author": "OpenTelemetry Authors",
  "license": "Apache-2.0",
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "files": [
    "doc",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.130",
    "@types/sinon": "17.0.4",
    "mocha": "11.7.5",
    "nyc": "17.1.0",
    "sinon": "18.0.1",
    "ts-loader": "9.5.4",
    "typescript": "5.0.4"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.3.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/otlp-exporter-base": "0.217.0",
    "@opentelemetry/otlp-transformer": "0.217.0"
  },
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/experimental/packages/otlp-grpc-exporter-base",
  "sideEffects": false
}
